function _arquivarAbaIndividual(nomeOrigem, nomeDestino) {
  const planilhaHistorico = SpreadsheetApp.openById(ID_PLANILHA_HISTORICO);
  const planilhaAtiva     = SpreadsheetApp.getActiveSpreadsheet();
  const corte             = new Date();
  corte.setDate(corte.getDate() - DIAS_RETENCAO);

  const arquivadas = arquivarAba(planilhaAtiva, planilhaHistorico, nomeOrigem, nomeDestino, corte);
  console.log('✅ ' + nomeOrigem + ': ' + arquivadas + ' mensagens arquivadas.');
}

// ----- Motor de arquivamento (processa no máximo LOTE_ARQUIVAMENTO linhas por vez) -----
function arquivarAba(planilhaOrigem, planilhaDestino, nomeOrigem, nomeDestino, dataCorte) {
  const abaOrigem  = planilhaOrigem.getSheetByName(nomeOrigem);
  const abaDestino = planilhaDestino.getSheetByName(nomeDestino);

  if (!abaOrigem || !abaDestino) {
    console.warn('⚠️ Aba não encontrada: ' + nomeOrigem + ' ou ' + nomeDestino);
    return 0;
  }

  const ultimaLinha = abaOrigem.getLastRow();
  if (ultimaLinha < 2) return 0;

  const totalDados = ultimaLinha - 1;
  const dados = abaOrigem.getRange(2, 1, totalDados, 11).getValues();

  const linhasParaArquivar = [];
  let loteContador = 0;

  for (let i = 0; i < dados.length && loteContador < LOTE_ARQUIVAMENTO; i++) {
    const dataCell = dados[i][0];
    if (!dataCell || !(dataCell instanceof Date)) continue;

    if (dataCell < dataCorte) {
      linhasParaArquivar.push({
        indiceSheet: i + 2,
        valores: dados[i]
      });
      loteContador++;
    }
  }

  if (linhasParaArquivar.length === 0) return 0;

  // ETAPA 1: Copia para o histórico em bloco
  const valoresParaCopiar    = linhasParaArquivar.map(function(l) { return l.valores; });
  const proximaLinhaDestino  = abaDestino.getLastRow() + 1;
  abaDestino
    .getRange(proximaLinhaDestino, 1, valoresParaCopiar.length, 11)
    .setValues(valoresParaCopiar);

  // ETAPA 2: Deleta da origem de baixo para cima, agrupando linhas contíguas
  const indicesSheet = linhasParaArquivar
    .map(function(l) { return l.indiceSheet; })
    .sort(function(a, b) { return b - a; });

  let i = 0;
  while (i < indicesSheet.length) {
    let inicio    = indicesSheet[i];
    let quantidade = 1;

    while (
      i + quantidade < indicesSheet.length &&
      indicesSheet[i + quantidade] === inicio - quantidade
    ) {
      quantidade++;
    }

    abaOrigem.deleteRows(inicio - quantidade + 1, quantidade);
    i += quantidade;
  }

  return linhasParaArquivar.length;
}
