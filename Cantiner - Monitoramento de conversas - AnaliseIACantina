  MAPA_ARQUIVAMENTO.forEach(function(mapa) {
    try {
      const arquivadas = arquivarAba(planilhaAtiva, planilhaHistorico, mapa.origem, mapa.destino, corte);
      totalArquivadas += arquivadas;
      console.log('✅ ' + mapa.origem + ': ' + arquivadas + ' mensagens arquivadas.');
    } catch (err) {
      console.error('❌ Erro em ' + mapa.origem + ': ' + err.toString());
      try {
        const abaErro = planilhaAtiva.getSheetByName(mapa.origem);
        if (abaErro) {
          abaErro.appendRow([
            new Date(), 'ERRO_ARQUIVAMENTO', '', err.toString(),
            '', '', 'ERRO', '', '', '', 'arquivamento'
          ]);
        }
      } catch(e2) {}
    }
  });

  // Log final
  try {
    const abaLog = planilhaAtiva.getSheetByName('CANTINA_DIGISAC');
    if (abaLog) {
      abaLog.appendRow([
        new Date(), 'LOG_ARQUIVAMENTO', '',
        'Arquivamento concluído: ' + totalArquivadas + ' mensagens movidas para o histórico.',
        '', '', 'LOG', '', '', '', 'arquivamento'
      ]);
    }
  } catch(e) {}

  console.log('🎉 Total arquivado: ' + totalArquivadas + ' mensagens.');
}

