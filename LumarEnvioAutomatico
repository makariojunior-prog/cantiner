    'Simulação concluída! (' + diaHoje + ')\n\n' +
    clientes.length + ' cliente(s) receberiam mensagem.\n' +
    'Tempo estimado de envio: ~' + minEstimados + ' minutos\n' +
    '(iniciando às 06h00 → termina por volta das ' + _calcularHoraFim(6, 0, minEstimados) + ')\n\n' +
    clientes.map((c, i) => (i + 1) + '. ' + c.cliente + '  |  ' + c.telefone).join('\n') +
    '\n\nResultados registrados em LOG-ENVIOS.\nConfira se a lista bate com o Dashboard-L!'
  );
